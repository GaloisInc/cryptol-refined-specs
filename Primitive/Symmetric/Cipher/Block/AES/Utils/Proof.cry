/**
Cryptol functions which are not used in the specs themselves but are used in the
SAW script to simplify the proofs.
*/
module Primitive::Symmetric::Cipher::Block::AES::Utils::Proof where

import Primitive::Symmetric::Cipher::Block::AES::Utils::BitSlice

/**
Given a series of round keys in bitsliced format, get the round key for round
`i` (starting from 0).
*/
sliceRound : {i, n} (fin i, i < n) => [n * 8][64] -> FSState
sliceRound xs = take (drop`{i * 8} xs)

/**
Given a series of round keys in bitsliced format, modify the round key for round
`i` (starting from 0) using the given function.
*/
modifyRound : {i, n} (fin i, i < n)
           => (FSState -> FSState) -> [n * 8][64] -> [n * 8][64]
modifyRound f xs = take`{i * 8} xs
                 # f (sliceRound`{i} xs)
                 # drop`{(i + 1) * 8} xs
